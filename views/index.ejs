<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head", { title: "Inventory Dashboard" }) %>
  </head>
  <body>
    <%- include("partials/header", { currentPath: "/" }) %>

    <main class="page-shell">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Graduate Databases Project</p>
          <h1>IT inventory dashboard</h1>
          <p class="hero-text">
            This simple UI focuses on the <code>computers</code> table so you can
            create, review, edit, and delete device records without touching SQL
            directly.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/computers">Open computers table</a>
            <a class="button button-secondary" href="/computers/new">Add a computer</a>
          </div>
        </div>
        <div class="summary-grid">
          <article class="stat-card">
            <span class="stat-label">Total computers</span>
            <strong><%= summary.total_computers %></strong>
          </article>
          <article class="stat-card">
            <span class="stat-label">Available</span>
            <strong><%= summary.available_count %></strong>
          </article>
          <article class="stat-card">
            <span class="stat-label">Assigned</span>
            <strong><%= summary.assigned_count %></strong>
          </article>
          <article class="stat-card">
            <span class="stat-label">Loaners</span>
            <strong><%= summary.loaner_count %></strong>
          </article>
        </div>
      </section>

      <section class="panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Recent Rows</p>
            <h2>Latest computer records</h2>
          </div>
          <a class="text-link" href="/computers">View full table</a>
        </div>

        <% if (recentComputers.length === 0) { %>
          <p class="empty-state">
            No computer records exist yet. Use the add form to create the first one.
          </p>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Asset Tag</th>
                  <th>Type</th>
                  <th>Make / Model</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% recentComputers.forEach((computer) => { %>
                  <tr>
                    <td><%= computer.computer_id %></td>
                    <td><%= computer.asset_tag %></td>
                    <td><%= computer.device_type %></td>
                    <td><%= [computer.manufacturer, computer.model].filter(Boolean).join(" ") || "Not provided" %></td>
                    <td><span class="status-pill status-<%= computer.status %>"><%= computer.status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </body>
</html>
