<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head", { title: pageTitle }) %>
  </head>
  <body>
    <%- include("partials/header", { navKey }) %>

    <main class="page-shell">
      <section class="panel">
        <span class="eyebrow">Application message</span>
        <h1><%= title %></h1>
        <p class="error-copy"><%= errorDetails %></p>
        <div class="hero-actions">
          <a class="button button-primary" href="/computers">Open inventory</a>
          <a class="button button-secondary" href="/reports">View reports</a>
        </div>
      </section>
    </main>
  </body>
</html>
