<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head", { title: pageTitle }) %>
  </head>
  <body>
    <%- include("partials/header", { navKey }) %>

    <main class="page-shell">
      <section class="panel">
        <div class="section-heading">
          <div>
            <span class="eyebrow">Inventory admin</span>
            <h1><%= title %></h1>
            <p class="section-copy"><%= intro %></p>
          </div>

          <% if (createHref) { %>
            <a class="button button-primary" href="<%= createHref %>">
              <%= createLabel || "Add record" %>
            </a>
          <% } %>
        </div>

        <%- include("partials/flash", { successMessage, errorMessage }) %>

        <% if (rows.length === 0) { %>
          <p class="empty-state"><%= emptyMessage || "No rows found." %></p>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <% columns.forEach((column) => { %>
                    <th><%= column.label %></th>
                  <% }) %>
                  <% if (rowActions && rowActions.length > 0) { %>
                    <th>Actions</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% rows.forEach((row) => { %>
                  <tr>
                    <% columns.forEach((column) => { %>
                      <% const value = column.render ? column.render(row) : row[column.key]; %>
                      <% const cellClass = typeof column.cellClass === "function" ? column.cellClass(row) : (column.cellClass || ""); %>
                      <td class="<%= cellClass %>">
                        <% if (column.isHtml) { %>
                          <%- value %>
                        <% } else { %>
                          <%= value === null || value === undefined || value === "" ? "—" : value %>
                        <% } %>
                      </td>
                    <% }) %>

                    <% if (rowActions && rowActions.length > 0) { %>
                      <td>
                        <div class="action-row">
                          <% rowActions.forEach((action) => { %>
                            <% if (!action.when || action.when(row)) { %>
                              <% const href = action.href(row); %>
                              <% const className = action.className || "button-secondary"; %>
                              <% if (action.method === "post") { %>
                                <form action="<%= href %>" method="post" onsubmit="<%= action.confirm ? `return confirm('${action.confirm}')` : '' %>">
                                  <button class="button button-compact <%= className %>" type="submit">
                                    <%= action.label %>
                                  </button>
                                </form>
                              <% } else { %>
                                <a class="button button-compact <%= className %>" href="<%= href %>">
                                  <%= action.label %>
                                </a>
                              <% } %>
                            <% } %>
                          <% }) %>
                        </div>
                      </td>
                    <% } %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </body>
</html>
