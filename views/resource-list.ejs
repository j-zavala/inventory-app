<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head", { title: pageTitle }) %>
  </head>
  <body>
    <%- include("partials/header", { navItems, navKey }) %>

    <main class="page-shell">
      <section class="panel">
        <div class="section-heading">
          <div>
            <h1><%= title %></h1>
            <p><%= intro %></p>
          </div>

          <a class="button button-primary" href="<%= createHref %>">
            <%= createLabel %>
          </a>
        </div>

        <%- include("partials/flash", { successMessage, errorMessage }) %>

        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <% columns.forEach((column) => { %>
                  <th><%= column.label %></th>
                <% }) %>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach((row) => { %>
                <tr>
                  <% columns.forEach((column) => { %>
                    <% const value = row[column.key]; %>
                    <td>
                      <% if (value instanceof Date) { %>
                        <%= value.toISOString().slice(0, 10) %>
                      <% } else { %>
                        <%= value === null || value === undefined || value === "" ? "-" : value %>
                      <% } %>
                    </td>
                  <% }) %>
                  <td>
                    <div class="action-row">
                      <% rowActions.forEach((action) => { %>
                        <% if (action.method === "post") { %>
                          <form action="<%= action.href(row) %>" method="post" onsubmit="return confirm('<%= action.confirm %>')">
                            <button class="button button-small <%= action.className %>" type="submit">
                              <%= action.label %>
                            </button>
                          </form>
                        <% } else { %>
                          <a class="button button-small" href="<%= action.href(row) %>">
                            <%= action.label %>
                          </a>
                        <% } %>
                      <% }) %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
