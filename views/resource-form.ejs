<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head", { title: pageTitle }) %>
  </head>
  <body>
    <%- include("partials/header", { navItems, navKey }) %>

    <main class="page-shell">
      <section class="panel">
        <h1><%= title %></h1>
        <p><%= intro %></p>

        <%- include("partials/flash", { successMessage: null, errorMessage }) %>

        <form action="<%= formAction %>" class="entity-form" method="post">
          <%- include("partials/form-fields", { fields, record }) %>

          <div class="form-actions">
            <button class="button button-primary" type="submit">
              <%= submitLabel %>
            </button>
            <a class="button" href="<%= cancelHref %>">Cancel</a>
          </div>
        </form>
      </section>
    </main>
  </body>
</html>
