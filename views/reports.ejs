<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head", { title: pageTitle }) %>
  </head>
  <body>
    <%- include("partials/header", { navItems, navKey }) %>

    <main class="page-shell">
      <section class="panel">
        <h1>Report</h1>
        <p>This page reads from the single aggregate view, <code>v_computers_by_status</code>.</p>

        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Status</th>
                <th>Computer count</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach((row) => { %>
                <tr>
                  <td><%= row.status %></td>
                  <td><%= row.computer_count %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
